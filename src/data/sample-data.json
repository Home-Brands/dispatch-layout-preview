  "_meta": {
    "models": {
      "route": "A named lane on the dispatch board. Flexible by design — can represent an install crew, a sales rep, a service technician, a remediation team, or any other unit a brand wants to schedule against. Each route has its own color and one or more assigned members.",
      "member": "A person assigned to a route. Typically a technician or sales rep; a route can have one or more members.",
      "visit": "A scheduled unit of field work placed on a route at a specific day and time. Carries customer, property, service type, duration, and current status.",
      "visitStatus": "A configurable label + color that represents where a visit is in its lifecycle. The default set covers Scheduled, En route, On site, Completed, Cancelled, and No-show, but brands can add/edit these.",
      "unassignedVisit": "A visit that needs to be scheduled but has not yet been placed on a route. Lives in the unassigned queue panel.",
      "aiSuggestion": "A system-generated recommendation to place a specific unassigned visit on a specific route at a specific time, with a rationale.",
      "anomaly": "A system-flagged issue on a route — e.g., overbooked, impossible drive time, or missed SLA. Attached to a route with a reason and severity.",
      "weekRange": "The current date range displayed on the board (Monday through Sunday)."
    },
    "relationships": [
      "A route has many members",
      "A route has many visits (within a given week)",
      "A visit belongs to exactly one route",
      "A visit has one visitStatus",
      "An unassignedVisit becomes a visit when placed on a route",
      "An anomaly belongs to one route",
      "An aiSuggestion references one unassignedVisit and proposes one route + start time"
    ]
